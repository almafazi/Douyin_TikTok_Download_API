SERVER_HOST=0.0.0.0
SERVER_PORT=7789
CONFIG_PATH=/app/config.yaml
TIKTOK_API_KEY=
DEFAULT_VERSION=v1
FFMPEG_PATH=ffmpeg
ENVIRONMENT=development
GUNICORN_WORKERS=4
LOG_LEVEL=info
MAX_BODY_BYTES=1048576
# Kosongkan untuk in-memory fallback, atau set ke redis://host:6379/0
REDIS_URL=
# TTL cache hasil ekstraksi /tiktok (detik). CDN URL ~6 jam; 30 menit aman.
TIKTOK_EXTRACT_CACHE_TTL_SECONDS=1800
# TTL cache response /tiktok (detik). Harus < session TTL (300s).
TIKTOK_RESPONSE_CACHE_TTL_SECONDS=60
